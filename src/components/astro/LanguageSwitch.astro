---
import {
  LOCALE_ALTERNATES,
  LOCALE_LABELS,
  type Locale,
} from "../../lib/config";
import { switchLocalePath } from "../../lib/format";

type Props = {
  currentLocale: Locale;
  pathname: string;
};

const { currentLocale, pathname } = Astro.props;
const alternateLocale = LOCALE_ALTERNATES[currentLocale];
const alternatePath = switchLocalePath(pathname, alternateLocale);
---

<a
  href={alternatePath}
  data-preserve-hash-link
  class="inline-flex items-center gap-1.5 border px-3 py-1.5 text-[10px] font-bold tracking-[0.24em] uppercase transition"
  style="border-color: rgba(30,111,160,0.25); background-color: rgba(30,111,160,0.07); color: var(--color-accent);"
  onmouseover="this.style.backgroundColor='rgba(30,111,160,0.14)'; this.style.borderColor='rgba(30,111,160,0.5)';"
  onmouseout="this.style.backgroundColor='rgba(30,111,160,0.07)'; this.style.borderColor='rgba(30,111,160,0.25)';"
>
  <span>{LOCALE_LABELS[currentLocale].slice(0, 2)}</span>
  <span style="color: rgba(30,111,160,0.35);">/</span>
  <span style="color: rgba(30,111,160,0.55);"
    >{LOCALE_LABELS[alternateLocale].slice(0, 2)}</span
  >
</a>

<script is:inline>
  document.querySelectorAll("[data-preserve-hash-link]").forEach((element) => {
    element.addEventListener("click", (event) => {
      const link = event.currentTarget;
      if (!(link instanceof HTMLAnchorElement) || !window.location.hash) {
        return;
      }

      link.href = `${link.href}${window.location.hash}`;
    });
  });
</script>
