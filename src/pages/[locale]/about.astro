---
import BaseLayout from "../../layouts/BaseLayout.astro";

import { type Locale, SUPPORTED_LOCALES } from "../../lib/config";
import { getDictionary } from "../../lib/i18n";

export const getStaticPaths = () =>
  SUPPORTED_LOCALES.map((locale) => ({ params: { locale } }));

const locale = Astro.params.locale as Locale;
const dictionary = getDictionary(locale);
---

<BaseLayout
  locale={locale}
  pathname={`/${locale}/about`}
  title={`Dondeteveo | ${dictionary.about}`}
  description={dictionary.contactIntro}
  eyebrow={dictionary.about}
>
  <div
    class="max-w-3xl"
    style="background-color: var(--color-surface); border: 1px solid var(--color-line); padding: 1.5rem;"
  >
    <h1
      class="font-display text-5xl font-bold uppercase"
      style="color: var(--color-accent);"
    >
      {dictionary.about}
    </h1>
    <p
      class="mt-4 font-mono text-base leading-8"
      style="color: var(--color-muted);"
    >
      {dictionary.contactIntro}
    </p>
    <a
      href="https://jerna.digital"
      class="mt-6 inline-flex font-mono text-sm transition"
      style="color: var(--color-muted);"
      onmouseover="this.style.color='var(--color-accent)'"
      onmouseout="this.style.color='var(--color-muted)'">jerna.digital →</a
    >
  </div>
</BaseLayout>
